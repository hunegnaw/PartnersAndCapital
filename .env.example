# =================================================================
# Partners + Capital — Environment Variables
# =================================================================
# Copy this file to .env and fill in the values.
# Do NOT commit .env files to the repository.
# =================================================================

# Database (MySQL on Cloudways)
DATABASE_URL="mysql://user:password@localhost:3306/partnersandcapital"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"
# Generate with: openssl rand -base64 32

# Organization / White-label (fallback when no Organization record exists)
NEXT_PUBLIC_ORG_NAME="Partners + Capital"
NEXT_PUBLIC_PRIMARY_COLOR="#1e3a5f"
NEXT_PUBLIC_SECONDARY_COLOR="#2563eb"
NEXT_PUBLIC_ACCENT_COLOR="#f59e0b"

# Email (Elastic Email)
ELASTIC_EMAIL_API_KEY=""
EMAIL_FROM="noreply@yourdomain.com"
EMAIL_FROM_NAME="Partners + Capital"

# File Uploads
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE="52428800"  # 50MB in bytes

# File Encryption (32-byte hex string for AES-256-GCM)
ENCRYPTION_KEY=""
# Generate with: openssl rand -hex 32

# =================================================================
# Deploy Script Variables (only needed in .env.staging / .env.production)
# =================================================================
# SERVER_USER="your_cloudways_user"
# SERVER_HOST="your.server.com"
# SERVER_PATH="/home/user/applications/app/public_html"
# SSH_KEY="~/.ssh/id_rsa"
# DB_USER="database_user"
# DB_PASS="database_password"
# DB_NAME="database_name"
# DB_HOST="localhost"
# HEALTH_CHECK_HOST="yourdomain.com"
# NOTIFY_EMAIL="admin@yourdomain.com"
# SLACK_WEBHOOK=""
